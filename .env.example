# Convex Manager Environment Variables

# --- Ports ---
# The port the frontend dashboard will run on (Default: 8080)
FRONTEND_PORT=8080

# The internal port the backend API will run on (Default: 3001)
BACKEND_PORT=3001

# --- Security ---
# Secret used to sign JWT tokens. CHANGE THIS IN PRODUCTION!
JWT_SECRET=super_secret_jwt_key_change_in_production

# --- Database ---
# Credentials for the PostgreSQL database
DB_USER=postgres
DB_PASSWORD=convex_manager_secret
DB_NAME=convex_manager_db

# --- Registration & Auth ---
# Set to 'true' to allow anyone to register an account.
# If 'false', only admins can invite new users.
ALLOW_REGISTRATION=false

# --- Email / SMTP Settings (Required for Invitations & Password Resets) ---
# The base URL of your Convex Manager installation (used in email links)
APP_URL=http://localhost:8080

# Your SMTP server details
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
EMAIL_FROM="Convex Manager" <noreply@example.com>
